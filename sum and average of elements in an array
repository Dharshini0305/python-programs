# include<stdio.h>
int main(){
	int a[10],i,size,sum=0;
	float avg;
	printf("Enter the number of elements in an array:");
	scanf("%d",&size);
	printf("Enter the elements of the array:");
	for(i=0;i<size;i++)
	{
		scanf("%d",&a[i]);
	}
	for(i=0;i<size;i++){
		sum=sum+a[i];
	}
	printf("%d\n",sum);
	avg=sum/size;
	printf("%f",avg);
	return 0;
}
