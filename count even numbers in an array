# include<stdio.h>
int main(){
	int arr[10],size,i,count=0;
	printf("Enter the number of elements in an array:");
	scanf("%d",&size);
	printf("Enter the array elements:");
	for(i=0;i<size;i++){
		scanf("%d",&arr[i]);
	}
	for(i=0;i<size;i++){
		if(arr[i]%2==0){
			count++;
		}
}
printf("%d",count);
return 0;
}
