# include<stdio.h>
int main(){
	int a[10],i,size,n,count=0;
	printf("Enter the number of elements in an array:");
	scanf("%d",&size);
	printf("Enter the elements of the array:");
	for(i=0;i<size;i++)
	{
		scanf("%d",&a[i]);
	}
	for(i=0;i<size;i++){
		if(a[i]!=0){
			a[count]=a[i];
			count++;
		}
	}
		while(count<size){
			a[count]=0;
			count++;
	}
	for(i=0;i<size;i++)
	{
		printf("%d",a[i]);
	}
	return 0;
}
	
