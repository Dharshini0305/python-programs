int main(){
	int a[10],i,size,n,count=0;
	printf("Enter the number of elements in an array:");
	scanf("%d",&size);
	printf("Enter the elements of the array:");
	for(i=0;i<size;i++)
	{
		scanf("%d",&a[i]);
	}
	printf("Enter the element in an array whose frequency has to be counted");
	scanf("%d",&n);
	for(i=0;i<size;i++){
		if(a[i]==n){
			count++;
		}
	}
	printf("%d",count);
	return 0;
}
